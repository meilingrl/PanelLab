# 复制本文件为 .env 并填写实际配置（.env 已被 git 忽略）

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=panel_lab
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=panel_lab

# 可选：使用完整 URL 形式（若使用此项，后端可优先读取 DATABASE_URL）
# DATABASE_URL=mysql+pymysql://panel_lab:your_password@127.0.0.1:3306/panel_lab

# 应用
APP_ENV=development
SECRET_KEY=your-secret-key-change-in-production

# 首次初始化：创建表后若无用户则创建管理员（用户名 admin，密码如下）
INIT_ADMIN_PASSWORD=admin

# 可选：远程 Linux 监控（配置后系统监控页可切换「远程服务器」）
# REMOTE_SSH_HOST=192.168.1.100
# REMOTE_SSH_PORT=22
# REMOTE_SSH_USER=root
# REMOTE_SSH_KEY_PATH=.ssh/id_rsa
# REMOTE_SSH_PASSWORD=
